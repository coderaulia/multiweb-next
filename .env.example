# Public site base URL used for canonical links and sitemap entries.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional public URL used to rewrite `/media/...` and `/portfolio/...` asset paths to a CDN or S3 bucket.
# If empty, uploaded local assets use NEXT_PUBLIC_SITE_URL.
MEDIA_PUBLIC_BASE_URL=
NEXT_PUBLIC_MEDIA_BASE_URL=

# Initial admin user bootstrap for database-backed auth.
# The first login will create this admin user if admin_users is empty.
CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=change-this-password
CMS_ADMIN_NAME=Administrator

# Legacy fallback used only for compatibility and one-time bootstrap if no password is set.
CMS_ADMIN_TOKEN=

# PostgreSQL connection URL (required for database mode).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cms

# Optional direct migration URL if you want to keep runtime and migration credentials separate.
DATABASE_URL_MIGRATION=

# Optional Postgres pool cap for constrained hosting plans.
CMS_DB_POOL_MAX=

# Optional fixture preset for `npm run db:seed:file` when you want deterministic sample data.
CMS_SEED_FIXTURE=

# S3-compatible object storage (MinIO, Cloudflare R2, AWS S3).
# When set, admin media uploads are stored in S3 instead of the local public/ folder.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cms-media
S3_PUBLIC_URL=http://localhost:9000/cms-media
S3_REGION=us-east-1

# Optional storage quota in MB. Default 1000 MB.
CMS_STORAGE_QUOTA_MB=1000

# Optional fallback organization values for structured data.
CMS_ORG_NAME=Acme Marketing
CMS_ORG_LOGO=https://placehold.co/240x80/png

# Optional webhook URL to receive contact form submissions.
CONTACT_NOTIFICATION_WEBHOOK_URL=
CONTACT_NOTIFICATION_WEBHOOK_METHOD=POST
CONTACT_NOTIFICATION_WEBHOOK_TOKEN=

# Number of trusted reverse proxies in front of this app.
# Set to 0 for direct connections (no proxy). Set to 1 if behind Vercel, Cloudflare, or a single nginx.
# This determines how X-Forwarded-For is parsed for rate limiting - wrong values allow IP spoofing.
TRUSTED_PROXY_COUNT=0

# Optional application-level pepper for password hashing (hex-encoded, minimum 32 bytes / 64 hex chars).
# Provides defense-in-depth: if the DB is breached, passwords cannot be cracked without this secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Once set, existing users are transparently re-hashed on their next login.
PASSWORD_PEPPER=
